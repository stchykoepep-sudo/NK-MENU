-- ==================== STATE MANAGEMENT ====================
local CurrentMultiplier = 1.0
local OriginalSizes = {}
local ConnectedLabels = {}

-- Fungsi untuk mengunci teks KG agar tidak diubah kembali oleh skrip game asli
local function MonitorAndForceText(label)
    if ConnectedLabels[label] then return end
    ConnectedLabels[label] = true
    
    local function doUpdate()
        local text = label.Text
        local angkaAsli = text:match("[%d%.]+")
        if angkaAsli then
            local num = tonumber(angkaAsli)
            if num and num > 0 then
                local fakeValue = num * CurrentMultiplier
                local formatted = string.format("%.2fkg", fakeValue)
                label.Text = text:gsub(angkaAsli .. "%s*[Kk][Gg]", formatted):gsub(angkaAsli, formatted)
            end
        end
    end
    
    label:GetPropertyChangedSignal("Text"):Connect(doUpdate)
    doUpdate()
end

-- Fungsi Utama: Otomatis mendeteksi buah di kebun dan memanipulasinya
local function AutoDetectAndHackGarden()
    local char = LocalPlayer.Character
    
    -- Scan semua objek yang ada di Workspace dunia game
    for _, obj in pairs(workspace:GetDescendants()) do
        -- Proteksi: Pastikan bukan item yang nempel di badan atau tangan kita
        if not obj:IsDescendantOf(char) then
            
            -- 1. CARI AREA KEBUN (Mendeteksi model/folder bernama Plot, Garden, Farming, Crop, Plant)
            if obj:IsA("Model") or obj:IsA("Folder") then
                local folderName = obj.Name:lower()
                if folderName:find("plot") or folderName:find("garden") or folderName:find("farm") or folderName:find("plant") or folderName:find("crop") then
                    
                    -- Scan isi di dalam area kebun tersebut untuk mencari BUAH
                    for _, child in pairs(obj:GetDescendants()) do
                        
                        -- A. PERBESAR UKURAN VISUAL BUAH (UBAH KEGEDEAN)
                        if child:IsA("BasePart") and not child:IsA("Terrain") then
                            local childName = child.Name:lower()
                            -- Pastikan yang dibesarkan adalah komponen buah/tanaman, BUKAN tanah, pagar, atau alas plot
                            if not childName:find("dirt") and not childName:find("ground") and not childName:find("floor") and not childName:find("base") and not childName:find("zone") then
                                if not OriginalSizes[child] then
                                    OriginalSizes[child] = child.Size
                                end
                                -- Ubah visual buah menjadi besar raksasa sesuai multiplier menu
                                child.Size = OriginalSizes[child] * CurrentMultiplier
                            end
                        end
                        
                        -- B. SINKRONKAN DENGAN TEKS MELAYANG KG DI ATAS BUAH
                        if child:IsA("TextLabel") and child.Text:lower():find("kg") then
                            MonitorAndForceText(child)
                        end
                        
                    end
                end
            end
            
            -- 2. JALUR CADANGAN: Jika game meletakkan BillboardGui secara terpisah, tetap kita saring ketat
            if obj:IsA("BillboardGui") then
                local label = obj:FindFirstChildWhichIsA("TextLabel")
                if label and label.Text:lower():find("kg") then
                    MonitorAndForceText(label)
                    
                    -- Cari part fisik terdekat dari UI melayang ini untuk ikut dibesarkan
                    local targetPart = obj.Adornee or obj.Parent
                    if targetPart and targetPart:IsA("BasePart") then
                        if not targetPart.Name:lower():find("plot") and not targetPart.Name:lower():find("dirt") then
                            if not OriginalSizes[targetPart] then
                                OriginalSizes[targetPart] = targetPart.Size
                            end
                            targetPart.Size = OriginalSizes[targetPart] * CurrentMultiplier
                        end
                    end
                end
            end
            
        end
    end
end

-- Looping background super cepat (0.05 detik) agar deteksi kebun berjalan real-time instan
task.spawn(function()
    while true do
        pcall(AutoDetectAndHackGarden)
        task.wait(0.05)
    end
end)


