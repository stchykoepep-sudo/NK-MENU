-- ==================== STATE MANAGEMENT ====================
local CurrentMultiplier = 1.0
local OriginalSizes = {}

-- Fungsi Utama: Mengincar Murni Tanaman/Buah yang Tertanam di Garden
local function ApplyPerfectFruitMod()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj:IsA("Terrain") and not obj.Parent:IsA("Accessory") then
            local name = obj.Name:lower()
            local parentName = obj.Parent and obj.Parent.Name:lower() or ""
            
            local isPlantedFruit = name:find("stage") or name:find("crop") or name:find("plant") or name:find("carrot") or name:find("pineapple") or parentName:find("plants") or parentName:find("crops")
            local isInvalidObject = name:find("plot") or name:find("garden") or name:find("ground") or name:find("soil") or name:find("fence") or name:find("base") or obj.Parent:IsA("Tool") or parentName:find("plot")
            
            if isPlantedFruit and not isInvalidObject then
                if not OriginalSizes[obj] then
                    OriginalSizes[obj] = obj.Size
                end
                obj.Size = OriginalSizes[obj] * CurrentMultiplier
            end
        end
    end

    -- VISUAL BERAT KG DINAMIS
    for _, gui in pairs(game:GetDescendants()) do
        if gui:IsA("TextLabel") then
            local text = gui.Text
            if text:lower():find("kg") or text:lower():find("weight") then
                local angkaAsli = text:match("[%d%.]+")
                if angkaAsli then
                    local num = tonumber(angkaAsli)
                    if num and num > 0 then
                        local fakeKgValue = num * CurrentMultiplier
                        local formattedKg = string.format("%.1fkg", fakeKgValue)
                        gui.Text = text:gsub(angkaAsli .. "%s*[Kk][Gg]", formattedKg):gsub(angkaAsli, formattedKg)
                    end
                end
            end
        end
    end
end

task.spawn(function()
    while true do
        pcall(ApplyPerfectFruitMod)
        task.wait(0.2)
    end
end)


