-- ==================== STATE MANAGEMENT ====================
local CurrentMultiplier = 1.0
local OriginalSizes = {}
local ConnectedLabels = {}

-- Fungsi untuk memanipulasi teks secara paksa (Anti-Overwrite dari Game)
local function ForceTextUpdate(label)
    if ConnectedLabels[label] then return end
    ConnectedLabels[label] = true
    
    local function update()
        local text = label.Text
        if text:lower():find("kg") and not text:find("➔") then
            local angkaAsli = text:match("[%d%.]+")
            if angkaAsli then
                local num = tonumber(angkaAsli)
                if num and num > 0 then
                    local fakeKgValue = num * CurrentMultiplier
                    local formattedKg = string.format("%.2fkg", fakeKgValue)
                    
                    -- Putus sementara agar tidak menyebabkan infinite loop
                    label.Text = text:gsub(angkaAsli .. "%s*[Kk][Gg]", formattedKg):gsub(angkaAsli, formattedKg)
                end
            end
        end
    end
    
    -- Kunci: Setiap kali skrip game mencoba mengubah teks kembali ke aslinya, kita paksa timpa!
    label:GetPropertyChangedSignal("Text"):Connect(update)
    update()
end

-- Fungsi Utama: Mengubah Ukuran Buah via Adornee & Mengunci Teks KG
local function ApplyFruitChangerV6()
    local character = LocalPlayer.Character
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BillboardGui") and not obj:IsDescendantOf(character) then
            local label = obj:FindFirstChildWhichIsA("TextLabel")
            if label then
                local lowerText = label.Text:lower()
                if lowerText:find("kg") or lowerText:find("weight") then
                    
                    -- 1. PAKSA UBAH TEKS KG (ANTI REVERT)
                    ForceTextUpdate(label)
                    
                    -- 2. CARI MODEL BUAH ASLI LEWAT ADORNEE (AKURAT 100%)
                    -- Game Roblox modern menggunakan .Adornee untuk menempelkan UI di atas model part buah
                    local targetPart = obj.Adornee or obj.Parent
                    if targetPart and targetPart:IsA("BasePart") then
                        -- Cari model utamanya (Tempat buah/tanaman berada)
                        local modelContainer = targetPart:FindFirstAncestorOfClass("Model") or targetPart
                        
                        for _, part in pairs(modelContainer:GetDescendants()) do
                            if part:IsA("BasePart") and not part:IsA("Terrain") then
                                -- Proteksi agar part tanah/plot tidak ikut membesar
                                if not part.Name:lower():find("plot") and not part.Name:lower():find("dirt") and not part.Name:lower():find("ground") then
                                    if not OriginalSizes[part] then
                                        OriginalSizes[part] = part.Size
                                    end
                                    -- Perbesar visual buah raksasa secara real-time
                                    part.Size = OriginalSizes[part] * CurrentMultiplier
                                end
                            end
                        end
                    end
                    
                end
            end
        end
    end
end

-- Looping background super instan (0.05 detik) agar responsif
task.spawn(function()
    while task.wait(0.05) do
        pcall(ApplyFruitChangerV6)
    end
end)


