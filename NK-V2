-- Fungsi Inti: Mengubah Ukuran Buah & Teks Timbangan Kg
local function ApplyStrictModifications()
    -- 1. UBAH VISUAL UKURAN BUAH (ANTI KEBUN/PLOT MEMBESAR)
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj:IsA("Terrain") and not obj.Parent:IsA("Accessory") then
            local name = obj.Name:lower()
            local parentName = obj.Parent and obj.Parent.Name:lower() or ""
            
            -- Filter ketat: Hanya mengincar model wortel, nanas, atau buah murni
            local isTargetFruit = name:find("carrot") or name:find("pineapple") or name:find("fruit") or name:find("buah") or obj.Parent:IsA("Tool")
            -- Proteksi mutlak: Jangan sentuh area tanah kebun, pagar, baseplate biar tidak lag!
            local isGardenMesh = name:find("plot") or name:find("garden") or name:find("ground") or name:find("soil") or name:find("fence") or name:find("base") or parentName:find("garden") or parentName:find("plot")

            if isTargetFruit and not isGardenMesh then
                if not OriginalSizes[obj] then
                    OriginalSizes[obj] = obj.Size
                end
                -- Ubah ukuran visual buah murni
                obj.Size = OriginalSizes[obj] * CurrentMultiplier
            end
        end
    end

    -- 2. UBAH TEKS INDIKATOR TIMBANGAN KG (DINAMIS & REAL-TIME)
    for _, gui in pairs(game:GetDescendants()) do
        if gui:IsA("TextLabel") then
            local text = gui.Text
            if text:lower():find("kg") or text:lower():find("weight") then
                local angkaAsli = text:match("[%d%.]+")
                if angkaAsli then
                    local num = tonumber(angkaAsli)
                    if num and num > 0 then
                        local fakeKgValue = num * CurrentMultiplier
                        local formattedKg = string.format("%.2fkg", fakeKgValue)
                        -- Timpa teks Kg aslinya secara visual
                        gui.Text = text:gsub(angkaAsli .. "%s*[Kk][Gg]", formattedKg):gsub(angkaAsli, formattedKg)
                    end
                end
            end
        end
    end
end

-- Looping background super ringan (0.2 detik) biar hemat CPU HP kamu
task.spawn(function()
    while true do
        pcall(ApplyStrictModifications)
        task.wait(0.2)
    end
end)


