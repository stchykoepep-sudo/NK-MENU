-- Fungsi Sembunyikan UI & Ikon Bawaan Game secara Paksa
local function ToggleGameUI(status)
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    if pGui then
        for _, gui in pairs(pGui:GetDescendants()) do
            if gui:IsA("Frame") or gui:IsA("ImageLabel") or gui:IsA("ImageButton") or gui:IsA("TextButton") then
                local gName = gui.Name:lower()
                -- Target ikon buah, tombol Seeds, Garden, Sell, dan menu bawaan game
                if gName:find("icon") or gName:find("fruit") or gName:find("button") or gName:find("menu") or gName:find("seed") or gName:find("garden") or gName:find("sell") then
                    -- Pastikan tidak menyembunyikan Menu NK-Mod kita sendiri
                    if not gui:FindFirstAncestor("NK_FruitChangerUI") then
                        gui.Visible = not status
                    end
                end
            end
        end
    end
end

BtnHideUI.MouseButton1Click:Connect(function()
    GameUiHidden = not GameUiHidden
    if GameUiHidden then
        BtnHideUI.Text = "Hide Game UI: ON"
        BtnHideUI.TextColor3 = Color3.fromRGB(100, 255, 100)
        ToggleGameUI(true)
    else
        BtnHideUI.Text = "Hide Game UI: OFF"
        BtnHideUI.TextColor3 = Color3.fromRGB(200, 200, 200)
        ToggleGameUI(false)
    end
end)

