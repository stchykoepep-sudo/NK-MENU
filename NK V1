-- ==================== STATE MANAGEMENT ====================
local CurrentMultiplier = 1.0
local OriginalSizes = {}
local SEMBUNYIKAN_ICON = true -- Ganti ke false jika ingin memunculkan ikonnya lagi

-- Fungsi Utama Modifikasi Visual Buah, Teks Kg, dan Sembunyikan Ikon
local function ApplyUltimateModifications()
    -- 1. UBAH VISUAL UKURAN MODEL BUAH (DI PLOT & KARAKTER)
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj:IsA("Terrain") and not obj.Parent:IsA("Accessory") then
            local name = obj.Name:lower()
            local parentName = obj.Parent and obj.Parent.Name:lower() or ""
            
            if name:find("fruit") or name:find("carrot") or name:find("pineapple") or name:find("buah") or parentName:find("plot") or obj.Parent:IsA("Tool") then
                
                if not OriginalSizes[obj] then
                    OriginalSizes[obj] = obj.Size
                end
                
                -- Kalikan ukurannya secara visual sesuai multiplier tombol
                obj.Size = OriginalSizes[obj] * CurrentMultiplier
            end
        end
    end

    -- 2. UBAH TEKS INDIKATOR KG (MELAYANG DI ATAS BUAH & SCREEN)
    for _, gui in pairs(game:GetDescendants()) do
        if gui:IsA("TextLabel") then
            local text = gui.Text
            if text:lower():find("kg") or text:lower():find("weight") then
                local angkaAsli = text:match("[%d%.]+")
                if angkaAsli then
                    local num = tonumber(angkaAsli)
                    if num and num > 0 then
                        local fakeKgValue = num * CurrentMultiplier
                        local formattedKg = string.format("%.1fkg", fakeKgValue)
                        
                        gui.Text = text:gsub(angkaAsli .. "%s*[Kk][Gg]", formattedKg):gsub(angkaAsli, formattedKg)
                    end
                end
            end
        end
    end

    -- 3. FITUR SEMBUNYIKAN IKON BUAH / UI TERTENTU (VISUAL HIDE)
    if SEMBUNYIKAN_ICON then
        local pGui = LocalPlayer:FindFirstChild("PlayerGui")
        if pGui then
            for _, gui in pairs(pGui:GetDescendants()) do
                if gui:IsA("ImageLabel") or gui:IsA("ImageButton") then
                    -- Mencari ikon yang mendeteksi gambar buah atau tombol ikon di layar
                    if gui.Name:lower():find("icon") or gui.Image:lower():find("fruit") or gui.Name:lower():find("fruit") then
                        gui.Visible = false
                    end
                end
            end
        end
    end
end

-- Looping background super cepat (0.1 detik) biar responsif dan real-time
task.spawn(function()
    while true do
        pcall(ApplyUltimateModifications)
        task.wait(0.1)
    end
end)


