-- Fungsi Pembuat Tombol Kotak
local function CreateVideoBtn(name, text, pos)
    local Btn = Instance.new("TextButton")
    Btn.Name = name
    Btn.Text = text
    Btn.Size = UDim2.new(0, 135, 0, 42)
    Btn.Position = pos
    Btn.BackgroundColor3 = Color3.fromRGB(13, 9, 20)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 13
    Btn.TextColor3 = Color3.fromRGB(240, 240, 240)
    Btn.Parent = MainFrame
    
    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 6)
    Corner.Parent = Btn
    
    local LeftIndicator = Instance.new("Frame")
    LeftIndicator.Size = UDim2.new(0, 3, 1, -12)
    LeftIndicator.Position = UDim2.new(0, 4, 0, 6)
    LeftIndicator.BackgroundColor3 = Color3.fromRGB(110, 60, 220)
    LeftIndicator.BorderSizePixel = 0
    LeftIndicator.Parent = Btn
    
    return Btn
end

