-- ==================== STATE MANAGEMENT ====================
local CurrentMultiplier = 1.0
local OriginalSizes = {}

-- Fungsi Utama: Mengubah Ukuran Buah & Angka KG Secara Bersamaan
local function ApplyFruitSizeAndKgMod()
    -- Scan semua objek di dalam Dunia Game (Workspace)
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("TextLabel") then
            local text = obj.Text
            local lowerText = text:lower()
            
            -- Filter ketat: Teks wajib mengandung "kg" atau "weight" dan berada di dalam BillboardGui (Teks melayang di atas buah)
            if (lowerText:find("kg") or lowerText:find("weight")) and obj:FindFirstAncestorOfClass("BillboardGui") then
                
                -- PROTEKSI TOOL: Pastikan teks melayang ini bukan bagian dari Karakter kita (Bukan item di tangan/hotbar)
                if not obj:IsDescendantOf(LocalPlayer.Character) then
                    
                    -- 1. MANIPULASI ANGKA KG
                    local angkaAsli = text:match("[%d%.]+")
                    if angkaAsli then
                        local num = tonumber(angkaAsli)
                        if num and num > 0 then
                            local fakeKgValue = num * CurrentMultiplier
                            local formattedKg = string.format("%.2fkg", fakeKgValue)
                            obj.Text = text:gsub(angkaAsli .. "%s*[Kk][Gg]", formattedKg):gsub(angkaAsli, formattedKg)
                        end
                    end
                    
                    -- 2. UBAH UKURAN VISUAL BUAH (UBAH KEGEDEAN)
                    local billboard = obj:FindFirstAncestorOfClass("BillboardGui")
                    if billboard and billboard.Parent then
                        local targetModel = billboard.Parent -- Ini adalah Model tempat buah berada
                        
                        -- Besarkan semua MeshPart/Part buah tersebut sesuai multiplier menu
                        for _, part in pairs(targetModel:GetDescendants()) do
                            if part:IsA("BasePart") and not part:IsA("Terrain") then
                                if not OriginalSizes[part] then
                                    OriginalSizes[part] = part.Size
                                end
                                part.Size = OriginalSizes[part] * CurrentMultiplier
                            end
                        end
                    end
                    
                end
            end
        end
    end
end

-- Looping background super cepat (0.1 detik) agar instan pas di-klik multiplier-nya
task.spawn(function()
    while true do
        pcall(ApplyFruitSizeAndKgMod)
        task.wait(0.1)
    end
end)


